<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home Page</title>

    <!-- Link CSS -->
    <link rel="stylesheet" href="/css/styles.css">   
</head>

<style>
    .table-container{
        padding:15px 20px;
    }

    .title{
        font-size: 30px;
        font-weight: 600; /* ❌ bỏ px (600px sai) */
        padding-bottom:10px;
    }

    table {
        border-collapse: collapse;
        width: 100%;
    }

    th, td{
        padding:8px;
        text-align:left;
        border-bottom:1px solid #ddd;
    }

    tr:hover{
        background-color:coral;
    }
</style>

<body>

<!-- NAVBAR -->
<div class="topnav">
  <a class="active" href="/">Home</a> <!-- ❌ sửa lại cho đúng -->
  <a href="/create">Create Users</a>
</div>

<!-- TABLE -->
<div class="table-container">
    <div class="title">List Users</div>

    <table>

        <!-- HEADER -->
        <thead>
            <tr>
                <th>ID</th>
                <th>Email</th>
                <th>Name</th>
                <th>City</th>
                <th>Actions</th>
            </tr>
        </thead>

        <!-- BODY -->
        <tbody>
            <% for(let i = 0; i < ListUsers.length; i++){ %>
                <tr>
                    <td><%= ListUsers[i].id %></td>
                    <td><%= ListUsers[i].email %></td>
                    <td><%= ListUsers[i].name %></td>
                    <td><%= ListUsers[i].city %></td>
                    <td>
                        <button>Edit</button>
                        <button>Delete</button>
                    </td>
                </tr>
            <% } %>
        </tbody>

    </table>
</div>

</body>
</html>